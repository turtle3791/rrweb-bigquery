{
  "name": "@rrweb/bigquery-replay-backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./build/index.d.ts",
        "default": "./build/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsc -b",
    "check-types": "tsc -noEmit",
    "dev": "yarn build && node --watch build/cli.js",
    "prepublish": "yarn build",
    "start": "node build/cli.js",
    "lint": "yarn eslint src/**/*.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@google-cloud/bigquery": "^8.1.1",
    "@google-cloud/storage": "^7.17.3",
    "@rrweb/bigquery-replay-contracts": "0.0.0",
    "fastify": "^5.6.1"
  },
  "devDependencies": {
    "@types/node": "^24.5.2"
  }
}
